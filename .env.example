# Supabase 接続情報(値は .env.local に記載する。.env.local はコミット禁止)
# ローカル開発では `npx supabase start` の出力値を使う
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# service_role キーはサーバー専用。クライアント(NEXT_PUBLIC_)には絶対に置かない。
# P1 時点ではアプリからは未使用(テストのセットアップ用途のみ)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
